# =============================================
# Smart Ration System - Frontend Environment Variables
# Copy this to .env.local for development
# Set these as environment variables on Vercel
# =============================================

# Backend API URL (Render production URL)
REACT_APP_API_URL=https://your-api.onrender.com

# AI Module URL (if separate service)
REACT_APP_AI_URL=https://your-ai-module.onrender.com

# Firebase Web Config (from Firebase Console > Project Settings > Your Apps)
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id
REACT_APP_FIREBASE_VAPID_KEY=your_vapid_key

# Mappls Map API Key
REACT_APP_MAPPLS_API_KEY=your_mappls_api_key
