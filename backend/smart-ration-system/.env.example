# =============================================
# Smart Ration System - Backend Environment Variables
# Copy this file to a local .env (never commit .env)
# Set these as environment variables on Render
# =============================================

# Database (MySQL on Render or PlanetScale)
SPRING_DATASOURCE_URL=jdbc:mysql://YOUR_DB_HOST:3306/smart_ration_db?useSSL=true&serverTimezone=Asia/Kolkata
SPRING_DATASOURCE_USERNAME=your_db_username
SPRING_DATASOURCE_PASSWORD=your_db_password

# JWT (generate a long random string - min 64 chars)
JWT_SECRET=replace-with-a-very-long-random-secret-key-minimum-64-characters

# CORS (comma-separated, include your Vercel URL)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,capacitor://localhost

# MSG91 SMS (get from msg91.com dashboard)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=SMART
MSG91_TEMPLATE_ID=your_msg91_template_id

# OTP Debug Mode - MUST be false in production
OTP_DEBUG_MODE=false

# AI Module (if deployed separately)
AI_MODULE_URL=http://localhost:5000
